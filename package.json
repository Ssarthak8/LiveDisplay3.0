{
  "name": "room-scheduler",
  "version": "1.0.0",
  "private": true,
  "description": "Real-Time Room Scheduling and Live Display System",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/server\" \"npm run dev --workspace=apps/client\"",
    "dev:server": "npm run dev --workspace=apps/server",
    "dev:client": "npm run dev --workspace=apps/client",
    "build": "npm run build --workspace=packages/shared-types && npm run build --workspace=apps/server && npm run build --workspace=apps/client",
    "build:types": "npm run build --workspace=packages/shared-types",
    "seed": "npm run seed --workspace=apps/server",
    "lint": "concurrently \"npm run lint --workspace=apps/server\" \"npm run lint --workspace=apps/client\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
